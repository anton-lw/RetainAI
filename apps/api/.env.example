# Recommended production database:
# DATABASE_URL=postgresql+psycopg://retainai:retainai@localhost:5432/retainai
# Local development fallback:
DATABASE_URL=sqlite:///./retainai.db
MODEL_ARTIFACT_DIR=./artifacts
MLFLOW_TRACKING_URI=file:///./mlruns
MLFLOW_EXPERIMENT_NAME=retainai-dropout-models
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
AUTO_SEED=true
SEED_USER_PASSWORD=retainai-demo
JWT_SECRET_KEY=change-me-before-production
JWT_SECRET_KEY_FILE=
JWT_ACTIVE_KID=primary
JWT_LEGACY_KEYS=
JWT_ALGORITHM=HS256
JWT_ISSUER=retainai
JWT_AUDIENCE=retainai-api
ACCESS_TOKEN_EXPIRE_MINUTES=720
SESSION_IDLE_TIMEOUT_MINUTES=240
SESSION_TOUCH_INTERVAL_SECONDS=300
MAX_ACTIVE_SESSIONS_PER_USER=5
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_MINUTES=15
PRIVACY_TOKEN_KEY=
PRIVACY_TOKEN_KEY_FILE=
PRIVACY_TOKEN_KEY_LEGACY=
CONNECTOR_SECRET_KEY=
CONNECTOR_SECRET_KEY_FILE=
CONNECTOR_SECRET_KEY_LEGACY=
SECRET_BUNDLE_PATH=
CONNECTOR_REQUEST_TIMEOUT_SECONDS=30
CONNECTOR_MAX_PAGES=20
CONNECTOR_DEFAULT_PAGE_SIZE=500
WORKER_POLL_INTERVAL_SECONDS=10
JOB_BACKEND=db
JOB_MAX_ATTEMPTS=3
JOB_RETRY_BACKOFF_SECONDS=45
REDIS_URL=redis://localhost:6379/0
CELERY_TASK_ALWAYS_EAGER=false
DEPLOYMENT_LABEL=local-dev
DEPLOYMENT_REGION=eu-central
ENFORCE_RUNTIME_POLICY=false
FEDERATED_SECRET_KEY=
FEDERATED_SECRET_KEY_FILE=
FEDERATED_SECRET_KEY_LEGACY=
FEDERATED_CLIPPING_NORM=5.0
FEDERATED_NOISE_MULTIPLIER=0.02
FEDERATED_MIN_UPDATES=2
FEDERATED_UPDATE_MAX_AGE_SECONDS=1800
FEDERATED_ENCRYPT_PAYLOADS=true
SECURITY_HSTS_ENABLED=false
SECURITY_HSTS_MAX_AGE=31536000
SECURITY_REFERRER_POLICY=no-referrer
SECURITY_PERMISSIONS_POLICY=geolocation=(), microphone=(), camera=()
OBSERVABILITY_JSON_LOGS=true
OBSERVABILITY_LOG_LEVEL=INFO
OBSERVABILITY_METRICS_ENABLED=true
OBSERVABILITY_METRICS_PATH=/metrics
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,Accept
TRUSTED_HOSTS=localhost,127.0.0.1
HUGGINGFACE_SENTIMENT_ENABLED=false
HUGGINGFACE_SENTIMENT_MODEL=distilbert-base-uncased-finetuned-sst-2-english
SSO_ENABLED=false
SSO_MODE=header
SSO_PROVIDER_LABEL=
SSO_HEADER_EMAIL=X-SSO-Email
SSO_HEADER_NAME=X-SSO-Name
SSO_HEADER_ROLE=X-SSO-Role
SSO_OIDC_ISSUER_URL=
SSO_OIDC_AUTHORIZE_URL=
SSO_OIDC_TOKEN_URL=
SSO_OIDC_USERINFO_URL=
SSO_OIDC_JWKS_URL=
SSO_OIDC_CLIENT_ID=
SSO_OIDC_CLIENT_SECRET=
SSO_OIDC_SCOPES=openid profile email
SSO_OIDC_EMAIL_CLAIM=email
SSO_OIDC_NAME_CLAIM=name
SSO_OIDC_ROLE_CLAIM=role
SSO_OIDC_STATE_TTL_SECONDS=600
SSO_OIDC_ALLOWED_CLOCK_SKEW_SECONDS=60
BOOTSTRAP_ADMIN_NAME=RetainAI Administrator
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
ENVIRONMENT=development
